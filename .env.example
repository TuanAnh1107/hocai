DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=hocai
DB_SSL_ENABLED=false
DB_SSL_CA_PATH=
DB_SSL_REJECT_UNAUTHORIZED=true

DB_POOL_MAX=5
DB_POOL_MIN=0

# Required in production. Generate a long random string.
SESSION_SECRET=replace_with_a_long_random_secret
SESSION_COOKIE_NAME=connect.sid
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000
TRUST_PROXY=false

# Set to true only for first-time local setup if you want the app to auto-create schema.
AUTO_INIT_DB=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

PASSWORD_RESET_TOKEN_TTL_MINUTES=30
# Enable only in local development when you need to inspect password reset links.
SHOW_DEV_RESET_LINK=false
