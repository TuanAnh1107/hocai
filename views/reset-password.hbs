<main>
    <section class="login">
        <div class="login-container">
            <h1>Đặt lại mật khẩu<img src="/images/logo/web.png" alt="hocAI"></h1>

            {{#if successMessage}}
            <p class="success-message">{{successMessage}}</p>
            {{/if}}
            {{#if errorMessage}}
            <p class="error-message">{{errorMessage}}</p>
            {{/if}}

            <div class="login-box active">
                <h2>MẬT KHẨU MỚI</h2>
                {{#unless successMessage}}
                <form action="/reset-password" method="post">
                    <input type="hidden" name="token" value="{{token}}">
                    <p>Mật khẩu mới <span class="login-required-note">*</span></p>
                    <input type="password" name="newPassword" placeholder="Nhập mật khẩu mới" required>
                    <p>Xác nhận mật khẩu mới <span class="login-required-note">*</span></p>
                    <input type="password" name="confirmNewPassword" placeholder="Nhập lại mật khẩu mới" required>
                    <button type="submit">Cập nhật mật khẩu</button>
                </form>
                {{/unless}}
                <div class="login-text">
                    <p><a href="/login">Quay lại đăng nhập</a></p>
                </div>
            </div>
        </div>
    </section>
</main>
